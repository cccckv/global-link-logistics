# Database
DATABASE_URL="postgresql://logistics:password@localhost:5432/globallink"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Encryption (32 bytes hex for AES-256)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Stripe Payment
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Logistics Tracking API
AFTERSHIP_API_KEY="your-aftership-api-key"
# OR
TRACK17_API_KEY="your-17track-api-key"

# Mapbox
VITE_MAPBOX_TOKEN="your-mapbox-access-token"

# Cesium Ion
VITE_CESIUM_ION_TOKEN="your-cesium-ion-token"

# Backend
BACKEND_PORT=3000
BACKEND_HOST="0.0.0.0"

# Frontend URLs
VITE_API_BASE_URL="http://localhost:3000/api"
VITE_WS_URL="http://localhost:3000"

# CORS
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# Node Environment
NODE_ENV="development"
