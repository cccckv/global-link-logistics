generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                  @id @default(uuid())
  email              String?                 @unique
  passwordHash       String
  name               String
  phone              String                  @unique
  userType           UserType                @default(CUSTOMER)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  deletedAt          DateTime?
  userRole           UserRoleEnum            @default(USER)
  batchImportTasks   BatchImportTask[]
  pickupAddresses    OrderPickupAddress[]    @relation("UserPickupAddresses")
  recipientAddresses OrderRecipientAddress[] @relation("UserRecipientAddresses")
  payments           Payment[]
  markedOrders       QuickOrder[]            @relation("MarkUser")
  quickOrders        QuickOrder[]
  roles              UserRole[]
}

model VerificationCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  type      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, type, verified])
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  permissions String[]
  createdAt   DateTime   @default(now())
  users       UserRole[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model QuickOrder {
  id                 String                   @id @default(uuid())
  orderNumber        String                   @unique
  userId             String
  orderType          QuickOrderType
  warehouse          String?
  destination        String
  note               String?
  userMark           String?
  mark               String?
  originPort         String?
  destinationPort    String?
  batchTaskId        String?
  status             QuickOrderStatus         @default(PENDING)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  pickupAddressId    String?
  recipientAddressId String
  markUserId         String?
  shippedAt          DateTime?
  receivedAt         DateTime?
  containers         OrderContainer[]
  declarations       OrderDeclaration[]
  paymentCollections OrderPaymentCollection[]
  paymentVouchers    OrderPaymentVoucher[]
  payment            Payment?
  batchTask          BatchImportTask?         @relation(fields: [batchTaskId], references: [id])
  markUser           User?                    @relation("MarkUser", fields: [markUserId], references: [id])
  pickupAddress      OrderPickupAddress?      @relation("OrderPickupAddress", fields: [pickupAddressId], references: [id])
  recipientAddress   OrderRecipientAddress    @relation("OrderRecipientAddress", fields: [recipientAddressId], references: [id])
  user               User                     @relation(fields: [userId], references: [id])
  shipment           Shipment?

  @@index([userId, orderType, status, createdAt(sort: Desc)])
  @@index([markUserId, orderType, status, createdAt(sort: Desc)])
  @@index([orderNumber])
  @@index([batchTaskId])
  @@index([createdAt(sort: Desc)])
}

model OrderPickupAddress {
  id        String       @id @default(uuid())
  userId    String
  name      String
  company   String?
  phone     String
  region    String?
  address   String
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation("UserPickupAddresses", fields: [userId], references: [id], onDelete: Cascade)
  orders    QuickOrder[] @relation("OrderPickupAddress")

  @@unique([userId, phone])
  @@unique([userId, phone, name])
  @@index([userId, isDefault])
  @@index([userId, updatedAt])
}

model OrderRecipientAddress {
  id        String       @id @default(uuid())
  userId    String
  name      String
  company   String?
  phone     String
  region    String?
  address   String
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation("UserRecipientAddresses", fields: [userId], references: [id], onDelete: Cascade)
  orders    QuickOrder[] @relation("OrderRecipientAddress")

  @@unique([userId, phone])
  @@unique([userId, phone, name])
  @@index([userId, isDefault])
  @@index([userId, updatedAt])
}

model OrderDeclaration {
  id                 String                   @id @default(uuid())
  orderId            String
  trackingNumber     String?
  productName        String
  length             Decimal?                 @db.Decimal(8, 2)
  width              Decimal?                 @db.Decimal(8, 2)
  height             Decimal?                 @db.Decimal(8, 2)
  weight             Decimal                  @db.Decimal(10, 3)
  cnyUnitPrice       Decimal?                 @db.Decimal(10, 2)
  createdAt          DateTime                 @default(now())
  phpUnitPrice       Decimal?                 @db.Decimal(10, 2)
  order              QuickOrder               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentCollections OrderPaymentCollection[]

  @@index([orderId])
  @@index([productName])
}

model OrderContainer {
  id            String        @id @default(uuid())
  orderId       String
  containerType ContainerType
  quantity      Int
  weight        Decimal?      @db.Decimal(10, 2)
  productsJson  String?
  createdAt     DateTime      @default(now())
  order         QuickOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model BatchImportTask {
  id           String            @id @default(uuid())
  userId       String
  fileUrl      String
  fileName     String?
  fileSize     Int?
  warehouse    String
  destination  String
  status       BatchImportStatus @default(UPLOADING)
  totalRows    Int               @default(0)
  successCount Int               @default(0)
  failedCount  Int               @default(0)
  errorLog     String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id])
  orders       QuickOrder[]

  @@index([userId, status, createdAt(sort: Desc)])
}

model Shipment {
  id               String          @id @default(uuid())
  orderId          String?         @unique
  trackingNumber   String          @unique
  carrier          String
  originPort       String?
  destinationPort  String?
  departureDate    DateTime?
  arrivalDate      DateTime?
  estimatedArrival DateTime?
  currentLocation  String?
  currentLat       Float?
  currentLng       Float?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  quickOrderId     String?         @unique
  quickOrder       QuickOrder?     @relation(fields: [quickOrderId], references: [id])
  events           TrackingEvent[]
}

model TrackingEvent {
  id          String   @id @default(uuid())
  shipmentId  String
  status      String
  description String
  location    String
  lat         Float?
  lng         Float?
  timestamp   DateTime
  createdAt   DateTime @default(now())
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, timestamp])
}

model Payment {
  id              String        @id @default(uuid())
  orderId         String?       @unique
  userId          String
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  stripePaymentId String?
  paymentMethod   String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  quickOrderId    String?       @unique
  quickOrder      QuickOrder?   @relation(fields: [quickOrderId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
}

model OrderPaymentCollection {
  id                      String                @id @default(uuid())
  orderId                 String
  declarationId           String?
  channelUnitPricePhp     Decimal               @db.Decimal(10, 2)
  receivableFreightAmount Decimal               @db.Decimal(10, 2)
  receivableOtherAmount   Decimal?              @db.Decimal(10, 2)
  actualReceivedAmount    Decimal               @db.Decimal(10, 2)
  channelFreightCost      Decimal?              @db.Decimal(10, 2)
  channelOtherCost        Decimal?              @db.Decimal(10, 2)
  profit                  Decimal?              @db.Decimal(10, 2)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  declaration             OrderDeclaration?     @relation(fields: [declarationId], references: [id])
  order                   QuickOrder            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([declarationId])
  @@index([createdAt])
}

model OrderPaymentVoucher {
  id         String     @id @default(uuid())
  orderId    String
  fileUrl    String
  fileName   String?
  fileType   String?
  uploadedAt DateTime   @default(now())
  order      QuickOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

enum UserType {
  CUSTOMER
  EMPLOYEE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum QuickOrderType {
  SEA_LCL
  AIR
  LAND
  SEA_FCL
  PARCEL
  BATCH
}

enum QuickOrderStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum ContainerType {
  GP_20
  GP_40
  HQ_40
  HQ_45
}

enum BatchImportStatus {
  UPLOADING
  PARSING
  COMPLETED
  FAILED
  PARTIAL
}

enum UserRoleEnum {
  ADMIN
  USER
}
